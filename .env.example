# URL backend для leaderboard (опционально)
VITE_LEADERBOARD_API=https://your-bot-api.com

# Если API на другом домене — укажите базовый URL (обычно пусто, тот же Vercel)
# VITE_STATS_API=

# --- Переменные только на Vercel (Settings → Environment Variables), не в git ---

# Токен бота от @BotFather (проверка initData Mini App)
# BOT_TOKEN=123456:ABC...

# Upstash Redis (Vercel → Storage → Upstash Redis → Connect)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Секрет для просмотра статистики GET /api/stats (рекомендуется)
# STATS_READ_SECRET=your-long-random-string
